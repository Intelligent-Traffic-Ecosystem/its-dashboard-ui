PORT=5000

# Keycloak — all sensitive values live here, never in the frontend
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=its-realm
KEYCLOAK_CLIENT_ID=b3-dashboard
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_REDIRECT_URI=http://localhost:5000/api/auth/callback

# Where to send users after login
ADMIN_DASHBOARD_URL=http://localhost:3001
TRAFFIC_DASHBOARD_URL=http://localhost:3000
LOGIN_APP_URL=http://localhost:3003
DEV_LOGIN_REDIRECT_PATH=/api/auth/dev-login
DEV_LOGIN_DASHBOARD_URL=http://localhost:3000

# CORS — all frontend origins that can talk to the backend
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# B2 Data API adapter
B2_API_BASE_URL=http://localhost:8000
B2_WS_URL=ws://localhost:8000/ws/metrics
B2_REQUEST_TIMEOUT_MS=5000
B2_WS_RECONNECT_MS=3000
TRAFFIC_STALE_AFTER_SECONDS=30

# Dev bypass — set to true ONLY in local dev when Keycloak is not running
# Never set this in staging or production
DEV_BYPASS_AUTH=true

