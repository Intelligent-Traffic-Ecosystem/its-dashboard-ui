FROM node:22-alpine

WORKDIR /app

ENV NODE_ENV=production

COPY mock-producer/package*.json ./
RUN npm ci --omit=dev

COPY mock-producer/full-mock-b2-server.js ./
COPY mock-producer/mock-b2-server.js ./

EXPOSE 18000

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1:18000/health || exit 1

CMD ["node", "full-mock-b2-server.js"]
