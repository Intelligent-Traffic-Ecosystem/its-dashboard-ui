# Optional local compose image names
B3_BACKEND_IMAGE=its-b3-backend:latest
B3_TRAFFIC_DASHBOARD_IMAGE=its-b3-traffic-dashboard:latest
B3_LOGIN_IMAGE=its-b3-login:latest

# Backend runtime
PORT=5000
NODE_ENV=production
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=its-realm
KEYCLOAK_CLIENT_ID=b3-dashboard
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_REDIRECT_URI=http://localhost:5000/api/auth/callback
ADMIN_DASHBOARD_URL=http://localhost:3001
TRAFFIC_DASHBOARD_URL=http://localhost:3000
LOGIN_APP_URL=http://localhost:3003
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003
SWAGGER_SERVER_URL=http://localhost:5000

# B2 Data API adapter
B2_API_BASE_URL=http://b2-api:8000
B2_WS_URL=ws://b2-api:8000/ws/metrics
B2_REQUEST_TIMEOUT_MS=5000
B2_WS_RECONNECT_MS=3000
TRAFFIC_STALE_AFTER_SECONDS=30

# Traffic dashboard build/runtime.
# NEXT_PUBLIC_* values are baked into the browser bundle during docker build.
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_LOGIN_APP_URL=http://localhost:3003
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_ID=

# Login app runtime. This URL is used by the login app server route and should
# be reachable by the user's browser because it redirects the browser there.
BACKEND_URL=http://localhost:5000
