# ── Keycloak ────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=its-realm
KEYCLOAK_CLIENT_ID=b3-dashboard
KEYCLOAK_CLIENT_SECRET=your-client-secret-here
KEYCLOAK_REDIRECT_URI=http://localhost:5000/api/auth/callback

# ── Dashboard URLs (public — shown in browser redirects) ────────────────────
ADMIN_DASHBOARD_URL=http://localhost:3001
TRAFFIC_DASHBOARD_URL=http://localhost:3000
LOGIN_APP_URL=http://localhost:3003

# ── Backend URLs ─────────────────────────────────────────────────────────────
# Internal: used by login container to talk to backend inside Docker network
BACKEND_INTERNAL_URL=http://backend:5000
# Public: baked into traffic-dashboard JS bundle, called from the browser
BACKEND_PUBLIC_URL=http://localhost:5000

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# ── Google Maps (baked into traffic-dashboard bundle at build time) ──────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_MAPS_ID=DEMO_MAP_ID

# ── Dev only ─────────────────────────────────────────────────────────────────
DEV_BYPASS_AUTH=false
